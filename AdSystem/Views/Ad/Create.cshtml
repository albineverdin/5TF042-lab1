@{
    ViewData["Title"] = "Place Ad";
}

<h2>Place Ad</h2>

<div class="mb-4">
    <label class="form-label fw-bold">Advertiser type</label>
    <div>
        <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="advertiserType" id="typeSubscriber" value="subscriber" checked>
            <label class="form-check-label" for="typeSubscriber">Subscriber</label>
        </div>
        <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="advertiserType" id="typeCompany" value="company">
            <label class="form-check-label" for="typeCompany">Company</label>
        </div>
    </div>
</div>

@* Subscriber form *@
<div id="subscriberSection">
    <form asp-action="CreateSubscriberAd" method="post">
        @Html.AntiForgeryToken()

        <h4>Subscriber details</h4>

        <div class="row mb-3">
            <div class="col-md-4">
                <label class="form-label">Subscription number</label>
                <div class="input-group">
                    <input type="text" id="subscriptionNumberInput" name="SubscriptionNumber" class="form-control" required>
                    <button type="button" class="btn btn-outline-secondary" onclick="lookupSubscriber()">Fetch</button>
                </div>
                <div id="lookupError" class="text-danger mt-1" style="display:none">Subscriber not found.</div>
            </div>
        </div>

        <div id="subscriberDetails" style="display:none">
            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label">Name</label>
                    <input type="text" id="subName" name="Name" class="form-control">
                </div>
                <div class="col-md-4">
                    <label class="form-label">Phone</label>
                    <input type="text" id="subPhone" name="Phone" class="form-control">
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label">Address</label>
                    <input type="text" id="subAddress" name="Address" class="form-control">
                </div>
                <div class="col-md-2">
                    <label class="form-label">Postal code</label>
                    <input type="text" id="subPostalCode" name="PostalCode" class="form-control">
                </div>
                <div class="col-md-3">
                    <label class="form-label">City</label>
                    <input type="text" id="subCity" name="City" class="form-control">
                </div>
            </div>

            <hr>
            <h4>Ad details</h4>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label">Title</label>
                    <input type="text" name="Title" class="form-control" required>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label">Content</label>
                    <textarea name="Content" class="form-control" rows="3" required></textarea>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3">
                    <label class="form-label">Item price (SEK)</label>
                    <input type="number" name="ItemPrice" class="form-control" min="0" step="0.01" required>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Ad price</label>
                    <input type="text" class="form-control" value="0 SEK (subscriber)" readonly disabled>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Place ad</button>
        </div>
    </form>
</div>

@* Company form *@
<div id="companySection" style="display:none">
    <form asp-action="CreateCompanyAd" method="post">
        @Html.AntiForgeryToken()

        <h4>Company details</h4>

        <div class="row mb-3">
            <div class="col-md-4">
                <label class="form-label">Organisation number</label>
                <input type="text" name="OrganisationNumber" class="form-control" required>
            </div>
            <div class="col-md-4">
                <label class="form-label">Company name</label>
                <input type="text" name="Name" class="form-control" required>
            </div>
            <div class="col-md-4">
                <label class="form-label">Phone</label>
                <input type="text" name="Phone" class="form-control" required>
            </div>
        </div>
        <div class="row mb-3">
            <div class="col-md-4">
                <label class="form-label">Address</label>
                <input type="text" name="Address" class="form-control" required>
            </div>
            <div class="col-md-2">
                <label class="form-label">Postal code</label>
                <input type="text" name="PostalCode" class="form-control" required>
            </div>
            <div class="col-md-3">
                <label class="form-label">City</label>
                <input type="text" name="City" class="form-control" required>
            </div>
        </div>

        <h5>Invoice address</h5>
        <div class="row mb-3">
            <div class="col-md-4">
                <label class="form-label">Address</label>
                <input type="text" name="InvoiceAddress" class="form-control" required>
            </div>
            <div class="col-md-2">
                <label class="form-label">Postal code</label>
                <input type="text" name="InvoicePostalCode" class="form-control" required>
            </div>
            <div class="col-md-3">
                <label class="form-label">City</label>
                <input type="text" name="InvoiceCity" class="form-control" required>
            </div>
        </div>

        <hr>
        <h4>Ad details</h4>
        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label">Title</label>
                <input type="text" name="Title" class="form-control" required>
            </div>
        </div>
        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label">Content</label>
                <textarea name="Content" class="form-control" rows="3" required></textarea>
            </div>
        </div>
        <div class="row mb-3">
            <div class="col-md-3">
                <label class="form-label">Item price (SEK)</label>
                <input type="number" name="ItemPrice" class="form-control" min="0" step="0.01" required>
            </div>
            <div class="col-md-3">
                <label class="form-label">Ad price</label>
                <input type="text" class="form-control" value="40 SEK" readonly disabled>
            </div>
        </div>

        <button type="submit" class="btn btn-primary">Place ad</button>
    </form>
</div>

@section Scripts {
<script>
    // Toggle subscriber/company sections on radio change
    document.querySelectorAll('input[name="advertiserType"]').forEach(radio => {
        radio.addEventListener('change', function () {
            document.getElementById('subscriberSection').style.display =
                this.value === 'subscriber' ? 'block' : 'none';
            document.getElementById('companySection').style.display =
                this.value === 'company' ? 'block' : 'none';
        });
    });

    // Fetch subscriber data from API and pre-fill fields
    async function lookupSubscriber() {
        const number = document.getElementById('subscriptionNumberInput').value.trim();
        if (!number) return;

        const errorEl = document.getElementById('lookupError');
        const detailsEl = document.getElementById('subscriberDetails');

        try {
            const response = await fetch(`/Ad/LookupSubscriber?subscriptionNumber=${encodeURIComponent(number)}`);

            if (!response.ok) {
                errorEl.style.display = 'block';
                detailsEl.style.display = 'none';
                return;
            }

            const data = await response.json();
            errorEl.style.display = 'none';

            document.getElementById('subName').value = `${data.firstName} ${data.lastName}`;
            document.getElementById('subPhone').value = data.phoneNumber;
            document.getElementById('subAddress').value = data.address;
            document.getElementById('subPostalCode').value = data.postalCode;
            document.getElementById('subCity').value = data.city;

            detailsEl.style.display = 'block';
        } catch {
            errorEl.style.display = 'block';
            detailsEl.style.display = 'none';
        }
    }
</script>
}