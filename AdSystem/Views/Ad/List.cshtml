@model IEnumerable<AdSystem.Models.Ad>

@{
    ViewData["Title"] = "All Ads";
    string selectedCurrency = ViewBag.Currency ?? "SEK";
    decimal rate = ViewBag.Rate ?? 1m;
    var availableCurrencies = ViewBag.AvailableCurrencies as List<string> ?? new List<string> { "SEK" };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>All Ads</h2>
    <a asp-action="Create" class="btn btn-primary">Place new ad</a>
</div>

<form method="get" class="mb-4 d-flex align-items-center gap-2">
    <label class="form-label mb-0 fw-bold">Display prices in:</label>
    <select name="currency" class="form-select form-select-sm" style="width:auto">
        @foreach (var c in availableCurrencies)
        {
            <option value="@c" selected="@(c == selectedCurrency ? "selected" : null)">@c</option>
        }
    </select>
    <button type="submit" class="btn btn-sm btn-outline-secondary">Apply</button>
</form>

@if (!Model.Any())
{
    <p class="text-muted">No ads have been placed yet.</p>
}
else
{
    <div class="row">
        @foreach (var ad in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <strong>@ad.Title</strong>
                        @if (ad.Advertiser.Type == "company")
                        {
                            <span class="badge bg-warning text-dark">Company</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Subscriber</span>
                        }
                    </div>
                    <div class="card-body">
                        <p class="card-text">@ad.Content</p>
                        <ul class="list-unstyled mb-0">
                            <li><strong>Advertiser:</strong> @ad.Advertiser.Name</li>
                            <li><strong>Item price:</strong> @((ad.ItemPrice * rate).ToString("F2")) @selectedCurrency</li>
                            <li><strong>Ad price:</strong> @((ad.AdPrice * rate).ToString("F2")) @selectedCurrency</li>
                        </ul>
                    </div>
                </div>
            </div>
        }
    </div>
}
