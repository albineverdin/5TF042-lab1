@{
    ViewData["Title"] = "Home";
}

<div class="text-center mt-5">
    <h1 class="display-4">Ad System</h1>
    <p class="lead text-muted mb-5">Place ads as a subscriber or company, or browse all current ads.</p>
    <div class="d-flex justify-content-center gap-3">
        <a asp-controller="Ad" asp-action="Create" class="btn btn-primary btn-lg">Place Ad</a>
        <a asp-controller="Ad" asp-action="List" class="btn btn-outline-secondary btn-lg">View All Ads</a>
    </div>
</div>